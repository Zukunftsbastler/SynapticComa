    "test": "vitest run"
  },
  "dependencies": {
    "bitecs": "^0.3.40",
    "peerjs": "^1.5.4",
    "pixi.js": "^8.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
