{
  "name": "synaptic-coma",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "validate:levels": "tsx --tsconfig tsconfig.json scripts/validateLevels.ts",
    "validate:e2e": "playwright test",
